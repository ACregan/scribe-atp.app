{
  "name": "scribe-cms.app",
  "version": "5.11.8",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "dev": "concurrently -n app,image-service -c blue,green \"npm run dev:app\" \"npm run dev:image-service\"",
    "dev:app": "react-router dev",
    "dev:image-service": "tsx watch --env-file=.env image-service/src/index.ts",
    "start": "PORT=3008 react-router-serve ./build/server/index.js",
    "start:image-service": "tsx image-service/src/index.ts",
    "typecheck": "react-router typegen && tsc",
    "typecheck:image-service": "tsc -p image-service/tsconfig.json --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "bump:minor": "npm version minor --no-git-tag-version && git tag v$(node -p \"require('./package.json').version\")",
    "bump:patch": "npm version patch --no-git-tag-version && git tag v$(node -p \"require('./package.json').version\")"
  },
  "dependencies": {
    "@atproto/api": "^0.19.18",
    "@atproto/oauth-client-node": "^0.3.17",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@lexical/code": "^0.44.0",
    "@lexical/history": "^0.44.0",
    "@lexical/html": "^0.44.0",
    "@lexical/link": "^0.44.0",
    "@lexical/list": "^0.44.0",
    "@lexical/markdown": "^0.44.0",
    "@lexical/react": "^0.44.0",
    "@lexical/rich-text": "^0.44.0",
    "@lexical/selection": "^0.44.0",
    "@lexical/utils": "^0.44.0",
    "@react-router/node": "8.2.0",
    "@react-router/serve": "8.2.0",
    "@scribe-atp/core": "^3.8.0",
    "@scribe-atp/styles": "^1.1.3",
    "better-sqlite3": "^12.10.0",
    "classnames": "^2.5.1",
    "express": "^5.2.1",
    "isbot": "^5.1.36",
    "isomorphic-dompurify": "^3.17.0",
    "lexical": "^0.44.0",
    "multer": "^2.1.1",
    "pino": "^10.3.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router": "8.2.0",
    "recharts": "^3.9.1",
    "sharp": "^0.32.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@react-router/dev": "8.2.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^22",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.8",
    "concurrently": "^10.0.3",
    "jsdom": "^29.1.1",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vite": "^8.0.3",
    "vitest": "^4.1.8"
  }
}
