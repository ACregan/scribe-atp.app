# ── Required ──────────────────────────────────────────────────────────────────

# Signs the __session cookie. Must be at least 32 random characters.
# Also used by the Image Service for session verification — both processes
# must share the same value.
# Generate with: openssl rand -base64 32
SESSION_SECRET=

# ── Production ────────────────────────────────────────────────────────────────

# Base URL of the deployed app (e.g. https://scribe-atp.app).
# Drives the OAuth client_id and redirect_uri — required in production.
# PUBLIC_URL=https://your-domain.com

# ── Image Service ─────────────────────────────────────────────────────────────

# Absolute filesystem path where uploaded image Variants are stored.
# Required when running the Image Service (npm run start:image-service).
# IMAGE_STORAGE_ROOT=/var/scribe/images

# ── Development — real Bluesky OAuth (optional) ───────────────────────────────

# Set to "true" to use real Bluesky OAuth instead of the dev login bypass.
# Requires a tunnel (e.g. npx cloudflared tunnel --url http://localhost:5173)
# and PUBLIC_URL set to the tunnel HTTPS URL.
# DEV_USE_REAL_OAUTH=true

# Cloudflare tunnel hostname without https:// (e.g. abc123.trycloudflare.com).
# Added to Vite's allowedHosts so the dev server accepts requests from the tunnel.
# DEV_TUNNEL_HOST=abc123.trycloudflare.com

# Dev server port — defaults to 5173 if not set.
# DEV_PORT=5173
